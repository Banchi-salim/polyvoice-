POLYVOICE_MODE=Real
POLYVOICE_DEFAULT_SOURCE_LANGUAGE=en
POLYVOICE_DEFAULT_TARGET_LANGUAGE=ig
POLYVOICE_MAX_RESPONSE_WORDS=15
POLYVOICE_LATENCY_TARGET_MS=200


# Either GOOGLE_TRANSLATE_API_KEY (REST API key) OR GOOGLE_APPLICATION_CREDENTIALS
# (absolute path to a service-account JSON file) must be set. API key mode is simplest.
GOOGLE_APPLICATION_CREDENTIALS=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
DEEPGRAM_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
GROQ_API_KEY=

# WhatsApp Cloud API. These are needed only for live WhatsApp webhooks.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=polyvoice-local-dev
WHATSAPP_API_VERSION=v20.0
